        // Кнопка входа
        private void login_btn_Click(object sender, EventArgs e)
        {
            string user = login_username.Text.Trim();
            string pass = login_password.Text.Trim();

            // Проверяем, не пустые ли поля
            if (string.IsNullOrEmpty(user) || string.IsNullOrEmpty(pass))
            {
                MessageBox.Show("Please fill all blank fields", "Error Message", MessageBoxButtons.OK, MessageBoxIcon.Error);
                return;
            }

            // ИСПОЛЬЗУЕМ ВАШ КЛАСС MainClass для проверки
            if (MainClass.IsValidUser(user, pass))
            {
                MessageBox.Show("Login successfully!", "Information Message", MessageBoxButtons.OK, MessageBoxIcon.Information);

                // Переход на главную форму
                MainForm mainForm = new MainForm();
                this.Hide(); // Скрываем форму логина
                mainForm.ShowDialog();
                this.Close(); // Закрываем совсем после выхода из главной формы
            }
            else
            {
                MessageBox.Show("Incorrect Username or password!", "Error Message", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        // Кнопка закрытия приложения
        private void close_Click(object sender, EventArgs e)
        {
            if (MessageBox.Show("Are you want to close this app?", "Confirmation message", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
            {
                Application.Exit();
            }
        }

